# Supabase Configuration
# Get these from your Supabase Project Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: OpenAI API Key (if you're using OpenAI integration)
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Optional: Baidu Speech Recognition (if you're using Baidu speech services)
VITE_BAIDU_APP_ID=your-baidu-app-id
VITE_BAIDU_API_KEY=your-baidu-api-key
VITE_BAIDU_SECRET_KEY=your-baidu-secret-key
